<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>ICONS Blog Cover 7 – Creator Roster</title>
<style>
  @import url('https://fonts.googleapis.com/css2?family=Barlow+Condensed:ital,wght@0,400;0,700;0,900;1,400;1,700;1,900&family=Space+Mono:ital,wght@0,400;0,700;1,400&family=Caveat:wght@500;600;700&display=swap');

  * { margin: 0; padding: 0; box-sizing: border-box; }

  body {
    background: #0d0d0d;
    display: flex;
    align-items: center;
    justify-content: center;
    min-height: 100vh;
  }

  .cover {
    position: relative;
    width: 1280px;
    height: 720px;
    background: #C8F135;
    overflow: hidden;
    flex-shrink: 0;
  }

  /* dot grid */
  .cover::before {
    content: '';
    position: absolute;
    inset: 0;
    background-image: radial-gradient(circle, rgba(0,0,0,0.13) 1.3px, transparent 1.3px);
    background-size: 22px 22px;
    z-index: 0;
  }

  /* ── Big black right panel ── */
  .right-panel {
    position: absolute;
    top: 0; right: 0;
    width: 480px;
    height: 100%;
    background: #0d0d0d;
    z-index: 1;
  }

  /* ── Zigzag edge between panels ── */
  .zigzag {
    position: absolute;
    top: 0;
    right: 464px;
    width: 40px;
    height: 100%;
    z-index: 2;
    overflow: hidden;
  }

  .zigzag svg {
    width: 100%;
    height: 100%;
  }

  /* ── Month grid (calendar feel) on right panel ── */
  .month-grid {
    position: absolute;
    top: 50%;
    right: 30px;
    transform: translateY(-50%);
    width: 420px;
    z-index: 3;
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 8px;
    padding: 0 24px;
  }

  .month-cell {
    background: rgba(255,255,255,0.05);
    border: 1.5px solid rgba(255,255,255,0.10);
    border-radius: 10px;
    padding: 8px 10px;
    display: flex;
    flex-direction: column;
    gap: 4px;
    position: relative;
    overflow: hidden;
  }

  .month-cell.active {
    background: #C8F135;
    border-color: #C8F135;
  }

  .month-cell.pink-cell {
    background: #FF3EB5;
    border-color: #FF3EB5;
  }

  .month-cell.semi {
    background: rgba(200,241,53,0.12);
    border-color: rgba(200,241,53,0.25);
  }

  .month-name {
    font-family: 'Space Mono', monospace;
    font-size: 8px;
    font-weight: 700;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: rgba(255,255,255,0.4);
  }

  .month-cell.active .month-name,
  .month-cell.pink-cell .month-name { color: #000; }

  .month-bar-wrap {
    width: 100%;
    height: 4px;
    background: rgba(255,255,255,0.08);
    border-radius: 2px;
    overflow: hidden;
  }

  .month-bar {
    height: 100%;
    border-radius: 2px;
    background: rgba(255,255,255,0.3);
  }

  .month-cell.active .month-bar { background: #000; }
  .month-cell.pink-cell .month-bar { background: #fff; }
  .month-cell.semi .month-bar { background: #C8F135; }

  .month-count {
    font-family: 'Space Mono', monospace;
    font-size: 9px;
    font-weight: 700;
    color: rgba(255,255,255,0.25);
  }

  .month-cell.active .month-count { color: #000; }
  .month-cell.pink-cell .month-count { color: #fff; }
  .month-cell.semi .month-count { color: rgba(200,241,53,0.7); }

  /* ── Right panel header ── */
  .panel-header {
    position: absolute;
    top: 28px;
    right: 30px;
    width: 420px;
    z index: 3;
    padding: 0 24px;
    z-index: 3;
  }

  .panel-header-label {
    font-family: 'Space Mono', monospace;
    font-size: 9px;
    font-weight: 700;
    letter-spacing: 0.2em;
    color: #C8F135;
    text-transform: uppercase;
  }

  .panel-header-title {
    font-family: 'Barlow Condensed', sans-serif;
    font-weight: 900;
    font-style: italic;
    font-size: 28px;
    color: #fff;
    text-transform: uppercase;
    line-height: 1;
    margin-top: 2px;
  }

  /* ── Right panel footer ── */
  .panel-footer {
    position: absolute;
    bottom: 26px;
    right: 30px;
    width: 420px;
    z-index: 3;
    padding: 0 24px;
    display: flex;
    align-items: center;
    justify-content: space-between;
  }

  .budget-pill {
    background: #FF3EB5;
    color: #fff;
    font-family: 'Space Mono', monospace;
    font-size: 9px;
    font-weight: 700;
    letter-spacing: 0.14em;
    padding: 5px 14px;
    border-radius: 999px;
    text-transform: uppercase;
  }

  .roster-count {
    font-family: 'Barlow Condensed', sans-serif;
    font-weight: 900;
    font-style: italic;
    font-size: 42px;
    color: rgba(255,255,255,0.12);
    line-height: 1;
  }

  /* ── Left content ── */
  .left-content {
    position: absolute;
    top: 50%;
    left: 44px;
    transform: translateY(-50%);
    z-index: 4;
    max-width: 660px;
    display: flex;
    flex-direction: column;
    gap: 16px;
  }

  .eyebrow {
    display: flex;
    align-items: center;
    gap: 10px;
    font-family: 'Space Mono', monospace;
    font-size: 10px;
    font-weight: 700;
    letter-spacing: 0.2em;
    color: #000;
    text-transform: uppercase;
  }

  .eyebrow-star { color: #FF3EB5; font-size: 14px; }

  .headline {
    font-family: 'Barlow Condensed', sans-serif;
    font-weight: 900;
    font-style: italic;
    font-size: 122px;
    line-height: 0.83;
    color: #0d0d0d;
    text-transform: uppercase;
    letter-spacing: -0.02em;
  }

  .headline .white-box {
    background: #0d0d0d;
    color: #C8F135;
    padding: 0 10px;
    display: inline-block;
  }

  .headline .pink { color: #FF3EB5; }
  .headline .outline {
    -webkit-text-stroke: 3px #0d0d0d;
    color: transparent;
  }

  .sub-text {
    font-family: 'Caveat', cursive;
    font-size: 23px;
    font-weight: 600;
    color: rgba(0,0,0,0.6);
    line-height: 1.35;
    max-width: 480px;
  }

  /* ── Strategy pills ── */
  .pills {
    display: flex;
    gap: 8px;
    flex-wrap: wrap;
  }

  .pill {
    font-family: 'Space Mono', monospace;
    font-size: 9px;
    font-weight: 700;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    padding: 5px 14px;
    border-radius: 999px;
    border: 2px solid #000;
    color: #000;
    background: transparent;
  }

  .pill.dark {
    background: #0d0d0d;
    color: #C8F135;
    border-color: #0d0d0d;
  }

  .pill.pink {
    background: #FF3EB5;
    color: #fff;
    border-color: #FF3EB5;
  }

  /* ── Sparkles ── */
  .sparkle { position: absolute; z-index: 5; }
  .sp-1 { top: 48px;  left: 380px; width: 34px; }
  .sp-2 { bottom: 70px; left: 340px; width: 26px; }
  .sp-3 { top: 100px; left: 560px; width: 20px; }

  /* ── Corner brackets ── */
  .bracket { position: absolute; width: 20px; height: 20px; z-index: 6; }
  .bracket.tl { top: 14px; left: 14px; border-top: 2.5px solid #000; border-left: 2.5px solid #000; }
  .bracket.tr { top: 14px; right: 14px; border-top: 2.5px solid rgba(255,255,255,0.3); border-right: 2.5px solid rgba(255,255,255,0.3); }
  .bracket.bl { bottom: 14px; left: 14px; border-bottom: 2.5px solid #000; border-left: 2.5px solid #000; }
  .bracket.br { bottom: 14px; right: 14px; border-bottom: 2.5px solid rgba(255,255,255,0.3); border-right: 2.5px solid rgba(255,255,255,0.3); }

  /* ── Top label ── */
  .top-label {
    position: absolute;
    top: 17px; left: 44px;
    font-family: 'Space Mono', monospace;
    font-size: 10px; font-weight: 700;
    letter-spacing: 0.1em; color: #000;
    z-index: 6;
  }

  /* ── Branding ── */
  .branding {
    position: absolute;
    bottom: 16px; left: 44px;
    z-index: 6;
  }
  .branding .brand-name {
    font-family: 'Barlow Condensed', sans-serif;
    font-weight: 900; font-style: italic;
    font-size: 26px; color: #000;
    text-transform: uppercase; line-height: 1;
  }
  .branding .brand-url {
    font-family: 'Space Mono', monospace;
    font-size: 9px; font-weight: 700;
    letter-spacing: 0.14em; color: rgba(0,0,0,0.5);
  }
</style>
</head>
<body>
<div class="cover">

  <!-- Right black panel -->
  <div class="right-panel"></div>

  <!-- Zigzag divider -->
  <div class="zigzag">
    <svg viewBox="0 0 40 720" preserveAspectRatio="none" xmlns="http://www.w3.org/2000/svg">
      <polyline points="40,0 0,36 40,72 0,108 40,144 0,180 40,216 0,252 40,288 0,324 40,360 0,396 40,432 0,468 40,504 0,540 40,576 0,612 40,648 0,684 40,720 40,0"
        fill="#0d0d0d" stroke="none"/>
