  <!-- Corner brackets -->
  <div class="bracket tl"></div>
  <div class="bracket tr"></div>
  <div class="bracket bl"></div>
  <div class="bracket br"></div>

  <!-- Top label -->
  <div class="top-label">07 · STRATEGY GUIDE · VOL. 04 · MMXXVI</div>

  <!-- Right panel: month grid -->
  <div class="panel-header">
