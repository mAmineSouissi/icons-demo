      <div class="month-count">4 creators</div>
    </div>
    <div class="month-cell semi">
      <div class="month-name">JUL</div>
      <div class="month-bar-wrap"><div class="month-bar" style="width:30%"></div></div>
      <div class="month-count">2 creators</div>
    </div>
    <div class="month-cell semi">
      <div class="month-name">AUG</div>
      <div class="month-bar-wrap"><div class="month-bar" style="width:60%"></div></div>
      <div class="month-count">3 creators</div>
    </div>
    <div class="month-cell pink-cell">
      <div class="month-name">SEP</div>
      <div class="month-bar-wrap"><div class="month-bar" style="width:90%"></div></div>
      <div class="month-count">5 creators</div>
    </div>
    <div class="month-cell active">
      <div class="month-name">OCT</div>
      <div class="month-bar-wrap"><div class="month-bar" style="width:75%"></div></div>
      <div class="month-count">4 creators</div>
    </div>
    <div class="month-cell semi">
      <div class="month-name">NOV</div>
      <div class="month-bar-wrap"><div class="month-bar" style="width:85%"></div></div>
      <div class="month-count">4 creators</div>
    </div>
    <div class="month-cell active">
      <div class="month-name">DEC</div>
      <div class="month-bar-wrap"><div class="month-bar" style="width:100%"></div></div>
      <div class="month-count">5 creators</div>
    </div>
  </div>

  <div class="panel-footer">
    <div class="budget-pill">★ No Big Budget</div>
    <div class="roster-count">42+</div>
  </div>

  <!-- Left content -->
  <div class="left-content">
    <div class="eyebrow">
      <span class="eyebrow-star">★</span>
      Strategy Guide
    </div>

    <div class="headline">
      Build<br>
      Your<br>
      <span class="white-box">Roster.</span>
    </div>

    <div class="sub-text">A full year of creators —<br>planned, managed & paid<br>without breaking the bank.</div>

    <div class="pills">
      <div class="pill dark">Micro-creators</div>
      <div class="pill pink">Smart Budgeting</div>
      <div class="pill">Long-term Deals</div>
      <div class="pill dark">Vetting Process</div>
    </div>
  </div>

  <!-- Sparkles -->
  <div class="sparkle sp-1">
    <svg viewBox="0 0 100 100" xmlns="http://www.w3.org/2000/svg">
      <path d="M50 4 C50 4 58 42 96 50 C58 58 50 96 50 96 C50 96 42 58 4 50 C42 42 50 4 50 4Z"
        fill="#FF3EB5" stroke="#000" stroke-width="5" stroke-linejoin="round"/>
